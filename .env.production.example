# Copy to .env (repo root) for docker compose. Keep this file secret — .env is git-ignored.

# Postgres password for the bundled database (any strong value)
POSTGRES_PASSWORD=change-me-strong-db-password

# App secrets — ROTATE THESE before launch
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
API_KEY=change-me-programmatic-api-key

# Your domain for automatic HTTPS (e.g. app.dataguard.io). Use :80 for local test.
SITE_ADDRESS=:80

# Optional — real crypto gateway (else the mock provider is used)
NOWPAYMENTS_API_KEY=

# Backups (used by deploy/backup.sh)
BACKUP_PASSPHRASE=change-me-backup-encryption-key
# S3_BUCKET=your-space-name   # optional off-site upload (DO Spaces / S3)
