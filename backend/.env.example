# Copy to .env and fill in. If DATABASE_URL is unset, the app runs in-memory.
DATABASE_URL=postgresql://dataguard:CHANGE_ME@localhost:5432/dataguard
JWT_SECRET=change-this-in-production
API_KEY=demo-key
PORT=4000

# Optional — Apify / custom detection provider (also configurable from admin UI)
# DETECTION_API_URL=
# DETECTION_API_KEY=
